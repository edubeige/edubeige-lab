---
import BaseLayout from "../../components/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import { faqItems } from "../../lib/site";
---

<BaseLayout title="FAQ | edubeige-lab" navSection="faq">
  <PageIntro
    eyebrow="Help Center"
    title="학교망과 실습 환경에서 자주 막히는 문제"
    description="계정, 브라우저, 공유 링크, 복사/다운로드 오류처럼 연수 현장에서 자주 만나는 이슈를 빠르게 해결할 수 있도록 정리했습니다."
    accent="운영 체크포인트와 fallback 안내"
  />

  <section class="container section">
    <div class="support-strip">
      <div class="support-strip__item">
        <strong>학교망 대응</strong>
        <p>외부 서비스가 막히면 직접 링크와 대체 활동으로 전환</p>
      </div>
      <div class="support-strip__item">
        <strong>복사 fallback</strong>
        <p>클립보드가 막힌 환경에서도 프롬프트를 직접 가져갈 수 있게 안내</p>
      </div>
      <div class="support-strip__item">
        <strong>개인정보 주의</strong>
        <p>학생 이름과 민감 정보는 프롬프트 입력에서 제외</p>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="split-grid split-grid--faq">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Top Questions</p>
            <h2>자주 묻는 질문</h2>
          </div>
        </div>
        <div class="faq-grid">
          {faqItems.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>

      <aside class="sidebar-stack">
        <div class="content-panel content-panel--tight">
          <div class="section-header">
            <div>
              <p class="eyebrow">Fallback</p>
              <h2>운영자 체크포인트</h2>
            </div>
          </div>
          <div class="notice-stack">
            <div class="notice-card">
              <strong>링크 우선</strong>
              <p>외부 서비스는 embed보다 직접 링크 제공을 기본으로 유지합니다.</p>
            </div>
            <div class="notice-card">
              <strong>정적 파일 운영</strong>
              <p>자료는 저장소 내 정적 파일 또는 명시적 외부 링크로 관리합니다.</p>
            </div>
            <div class="notice-card">
              <strong>실습 전 점검</strong>
              <p>브라우저, 계정 로그인, 공유 링크 접근 가능 여부를 먼저 확인합니다.</p>
            </div>
          </div>
        </div>

        <div class="content-panel content-panel--tight">
          <div class="section-header">
            <div>
              <p class="eyebrow">Need Help</p>
              <h2>바로가기</h2>
            </div>
          </div>
          <div class="link-stack">
            <a class="link-card" href={`${import.meta.env.BASE_URL}resources`}>
              <strong>자료실 열기</strong>
              <small>안내 자료와 준비 체크리스트 다시 확인</small>
            </a>
            <a class="link-card" href={`${import.meta.env.BASE_URL}prompts`}>
              <strong>프롬프트 허브 열기</strong>
              <small>복사용 템플릿을 다시 검색</small>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
