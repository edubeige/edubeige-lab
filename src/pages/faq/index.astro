---
import BaseLayout from "../../components/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import { faqItems } from "../../lib/site";
---

<BaseLayout title="FAQ | edubeige-lab" navLabel="FAQ">
  <PageIntro
    eyebrow="FAQ"
    title="학교망과 실습 환경에서 자주 막히는 문제"
    description="계정, 브라우저, 공유 링크, 복사/다운로드 오류처럼 연수 현장에서 자주 만나는 이슈를 빠르게 해결할 수 있도록 정리했습니다."
    accent="대체 링크와 fallback 안내 포함"
  />

  <section class="container section">
    <div class="two-column">
      <div class="section-shell">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Top Questions</p>
            <h2>자주 묻는 질문</h2>
          </div>
        </div>
        <div class="faq-list">
          {faqItems.map((item) => (
            <article class="faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="section-shell">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Fallback</p>
            <h2>운영자가 바로 확인할 체크포인트</h2>
          </div>
        </div>
        <div class="notice-list">
          <div class="notice-item">외부 서비스는 embed 대신 직접 링크를 제공한다.</div>
          <div class="notice-item">학생 개인정보가 입력되는 프롬프트는 사용하지 않는다.</div>
          <div class="notice-item">복사 기능이 막히면 직접 선택 가능한 텍스트 fallback을 제공한다.</div>
          <div class="notice-item">자료는 저장소 내 정적 파일 또는 명시적 외부 링크로 운영한다.</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
