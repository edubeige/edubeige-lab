---
import BaseLayout from "../../components/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import { getGalleryItems } from "../../lib/site";

const gallery = await getGalleryItems();
const tools = [...new Set(gallery.map((item) => item.data.tool))];
const purposes = [...new Set(gallery.flatMap((item) => item.data.purposes))];
---

<BaseLayout title="사례 갤러리 | edubeige-lab" navLabel="Gallery">
  <PageIntro
    eyebrow="Gallery"
    title="적용 사례 갤러리"
    description="연수 후 실제 수업이나 안내 페이지에 적용한 결과물을 카드형으로 모아 보는 공간입니다."
    accent="도구와 활용 목적 중심 큐레이션"
  />

  <section class="container section">
    <div class="section-shell filters">
      <div class="filter-row">
        <input id="gallery-search" type="search" placeholder="사례 제목 또는 설명 검색" />
        <select id="gallery-tool">
          <option value="">도구 전체</option>
          {tools.map((tool) => <option value={tool}>{tool}</option>)}
        </select>
        <select id="gallery-purpose">
          <option value="">활용 목적 전체</option>
          {purposes.map((purpose) => <option value={purpose}>{purpose}</option>)}
        </select>
      </div>
      <div class="card-grid" id="gallery-grid">
        {gallery.map((item) => <GalleryCard item={item} />)}
      </div>
      <div id="gallery-empty" class="empty-state hidden">조건에 맞는 사례가 없습니다.</div>
    </div>
  </section>

  <script>
    const cards = Array.from(document.querySelectorAll("[data-gallery-card]"));
    const searchInput = document.querySelector("#gallery-search");
    const toolSelect = document.querySelector("#gallery-tool");
    const purposeSelect = document.querySelector("#gallery-purpose");
    const emptyState = document.querySelector("#gallery-empty");

    if (
      searchInput instanceof HTMLInputElement &&
      toolSelect instanceof HTMLSelectElement &&
      purposeSelect instanceof HTMLSelectElement
    ) {
      const dataset = cards.map((card) => {
        const payload = JSON.parse(card.getAttribute("data-searchable") ?? "{}");
        return { element: card, ...payload };
      });

      const render = () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        dataset.forEach((item) => {
          const haystack = `${item.title} ${item.summary} ${item.detail}`.toLowerCase();
          const matchesQuery = !query || haystack.includes(query);
          const matchesTool = !toolSelect.value || item.tool === toolSelect.value;
          const matchesPurpose = !purposeSelect.value || item.purposes.includes(purposeSelect.value);
          const visible = matchesQuery && matchesTool && matchesPurpose;
          item.element.classList.toggle("hidden", !visible);
          if (visible) visibleCount += 1;
        });

        if (emptyState instanceof HTMLElement) {
          emptyState.classList.toggle("hidden", visibleCount !== 0);
        }
      };

      [searchInput, toolSelect, purposeSelect].forEach((control) => control.addEventListener("input", render));
      render();
    }
  </script>
</BaseLayout>
