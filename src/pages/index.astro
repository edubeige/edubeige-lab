---
import BaseLayout from "../components/BaseLayout.astro";
import ScheduleCard from "../components/ScheduleCard.astro";
import {
  byIds,
  createPath,
  faqItems,
  formatDate,
  getEventBySlug,
  getModulesByEventId,
  getPrompts,
  getResources,
  getSiteConfig,
  toUiToken,
} from "../lib/site";

const site = await getSiteConfig();
if (!site) {
  throw new Error("site config is missing");
}

const featuredEvent = await getEventBySlug(site.data.featuredEventSlug);
if (!featuredEvent) {
  throw new Error("featured event is missing");
}

const modules = await getModulesByEventId(featuredEvent.data.id);
const prompts = await getPrompts();
const resources = await getResources();

const featuredPromptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))].slice(0, 2);
const featuredPrompts = byIds(prompts, featuredPromptIds);
const featuredResources = byIds(resources, featuredEvent.data.resourceIds).slice(0, 2);

const firstModule = modules[0];
const prepLink = featuredEvent.data.quickLinks.find((link) => link.url.includes("/faq"));
const promptLink = featuredEvent.data.quickLinks.find((link) => link.url.includes("/prompts"));
const shareLink =
  featuredEvent.data.quickLinks.find((link) => /^https?:\/\//.test(link.url)) ??
  featuredEvent.data.quickLinks[0];

const prepHref = createPath(import.meta.env.BASE_URL, prepLink?.url ?? "/faq");
const promptHref = createPath(import.meta.env.BASE_URL, promptLink?.url ?? "/prompts");
const shareHref = createPath(import.meta.env.BASE_URL, shareLink?.url ?? "/gallery");
---

<BaseLayout
  title="edubeige-lab"
  description="AI 연수를 처음 시작하는 선생님도 준비부터 실습, 결과 공유까지 순서대로 따라갈 수 있도록 돕는 안내형 연수 사이트"
  navSection="guide"
  shell="guide"
>
  <section class="landing-hero container">
    <div class="landing-hero__copy">
      <p class="eyebrow">Start Here</p>
      <h1>처음 오셨다면 이 순서대로 따라오세요</h1>
      <p class="landing-hero__summary">
        이 사이트는 오늘 연수에서 무엇을 먼저 하고, 어느 자료를 열고, 마지막에 어디에 공유해야 하는지
        순서대로 안내하는 페이지입니다. 처음이라면 아래 3단계만 따라가면 됩니다.
      </p>

      <div class="landing-hero__meta">
        <span class="library-pill">{formatDate(featuredEvent.data.date)}</span>
        <span class="tag">장소: {featuredEvent.data.venue}</span>
        <span class="tag">강사: {featuredEvent.data.speaker}</span>
      </div>

      <div class="button-row">
        <a class="button" href={prepHref}>준비부터 시작하기</a>
        <a class="button secondary" href={`${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>오늘 연수 보기</a>
        <a class="button ghost" href={promptHref}>프롬프트 라이브러리</a>
      </div>
    </div>

    <aside class="landing-hero__panel">
      <p class="landing-hero__panel-eyebrow">오늘 연수 순서</p>
      <ul class="landing-hero__steps">
        {modules.map((module, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <strong>{module.data.title}</strong>
              <small>{module.data.startTime} - {module.data.endTime}</small>
            </div>
          </li>
        ))}
      </ul>
      <p class="landing-hero__note">
        각 교시를 누르면 더 자세한 실습 순서와 복사해서 바로 쓸 프롬프트를 볼 수 있습니다.
      </p>
    </aside>
  </section>

  <section class="container section">
    <div class="landing-quick-grid">
      <a class="landing-quick-card is-primary" href={prepHref}>
        <span>Step 01</span>
        <strong>시작 전 준비하기</strong>
        <p>구글 로그인, 브라우저, 학교망 접속 여부를 먼저 확인하고 시작합니다.</p>
      </a>

      <a class="landing-quick-card" href={firstModule ? `${import.meta.env.BASE_URL}modules/${firstModule.data.slug}` : `${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>
        <span>Step 02</span>
        <strong>오늘 순서 따라가기</strong>
        <p>1교시부터 차례대로 열면 상세 실습 안내와 프롬프트가 함께 나옵니다.</p>
      </a>

      <a class="landing-quick-card" href={shareHref} target={shareHref.startsWith("http") ? "_blank" : undefined} rel={shareHref.startsWith("http") ? "noreferrer" : undefined}>
        <span>Step 03</span>
        <strong>결과 공유하기</strong>
        <p>오늘 만든 결과물은 마지막에 공유 공간이나 안내된 링크로 올리면 됩니다.</p>
      </a>
    </div>
  </section>

  <section class="container section">
    <div class="landing-grid">
      <div class="landing-section-card">
        <div class="section-header section-header--stacked">
          <div>
            <p class="eyebrow">Today Schedule</p>
            <h2>오늘 따라갈 단계</h2>
            <p class="section-summary">교시별로 눌러 들어가면 실습 순서, 프롬프트, 자료를 바로 확인할 수 있습니다.</p>
          </div>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>전체 연수 보기</a>
        </div>

        <div class="schedule-list">
          {modules.map((module, index) => (
            <ScheduleCard module={module} index={index} ctaLabel={`${index + 1}교시 열기`} />
          ))}
        </div>
      </div>

      <div class="landing-side-stack">
        <article class="landing-info-card">
          <p class="eyebrow">Ready Check</p>
          <h2>시작 전 먼저 확인하세요</h2>
          <ul class="manual-list manual-list--compact">
            {featuredEvent.data.notices.map((notice) => <li>{notice}</li>)}
          </ul>
          <a class="button secondary compact" href={prepHref}>준비 체크 보러 가기</a>
        </article>

        <article class="landing-info-card">
          <div class="section-header section-header--stacked">
            <div>
              <p class="eyebrow">Resources</p>
              <h2>오늘 필요한 자료</h2>
            </div>
            <a class="button ghost compact" href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
          </div>

          <div class="landing-resource-list">
            {featuredResources.map((resource) => {
              const typeToken = toUiToken(resource.data.type);
              return (
                <article class="landing-resource-item">
                  <div class="landing-resource-item__icon" data-type={typeToken}>
                    {resource.data.type.toUpperCase()}
                  </div>
                  <div class="landing-resource-item__body">
                    <span class="landing-resource-item__label">{resource.data.scope === "event" ? "오늘 연수 자료" : "공통 자료"}</span>
                    <h3>{resource.data.title}</h3>
                    <p>{resource.data.description}</p>
                  </div>
                  <a class="button secondary compact" href={resource.data.url} target="_blank" rel="noreferrer">
                    {resource.data.downloadLabel}
                  </a>
                </article>
              );
            })}
          </div>
        </article>

        <article class="landing-info-card">
          <p class="eyebrow">Share</p>
          <h2>마지막에는 여기로 공유하세요</h2>
          <p class="landing-info-card__summary">
            실습 결과물은 안내된 공유 공간에 올리면 강사와 다른 선생님이 함께 볼 수 있습니다.
          </p>
          <div class="button-row">
            <a class="button" href={shareHref} target={shareHref.startsWith("http") ? "_blank" : undefined} rel={shareHref.startsWith("http") ? "noreferrer" : undefined}>
              결과 공유하러 가기
            </a>
            <a class="button ghost" href={`${import.meta.env.BASE_URL}faq`}>문제 해결 보기</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="landing-support-grid">
      <article class="landing-support-card">
        <div class="section-header section-header--stacked">
          <div>
            <p class="eyebrow">Prompt Library</p>
            <h2>연수 중 바로 가져다 쓰는 프롬프트</h2>
            <p class="section-summary">막히는 순간에 바로 복사해서 쓸 수 있게 핵심 예시만 먼저 보여드립니다.</p>
          </div>
          <a class="button ghost compact" href={promptHref}>프롬프트 전체 보기</a>
        </div>

        <div class="landing-mini-prompt-list">
          {featuredPrompts.map((prompt) => (
            <article class="landing-mini-prompt">
              <div class="landing-mini-prompt__top">
                <span class="library-pill">{prompt.data.tool}</span>
                <span class="tag">{prompt.data.subjects[0] ?? "수업 활용"}</span>
              </div>
              <h3>{prompt.data.title}</h3>
              <p>{prompt.data.summary}</p>
              <div class="landing-mini-prompt__preview">
                <p>{prompt.data.template}</p>
              </div>
              <button class="button secondary compact" type="button" data-copy={prompt.data.template}>프롬프트 복사</button>
            </article>
          ))}
        </div>
      </article>

      <article class="landing-support-card">
        <div class="section-header section-header--stacked">
          <div>
            <p class="eyebrow">Need Help</p>
            <h2>막히면 이 순서로 해결하세요</h2>
            <p class="section-summary">가장 많이 묻는 문제를 먼저 정리했습니다. 학교망 문제도 여기서 바로 확인할 수 있습니다.</p>
          </div>
        </div>

        <ul class="manual-list manual-list--compact">
          {faqItems.slice(0, 3).map((item) => <li>{item.question}</li>)}
        </ul>

        <div class="landing-tool-row">
          {featuredEvent.data.toolLinks.map((tool) => (
            <a class="landing-tool-link" href={tool.url} target="_blank" rel="noreferrer">{tool.label}</a>
          ))}
        </div>

        <div class="button-row">
          <a class="button secondary compact" href={`${import.meta.env.BASE_URL}faq`}>문제 해결 전체 보기</a>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}resources`}>자료실 보기</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
