---
import BaseLayout from "../components/BaseLayout.astro";
import PromptCard from "../components/PromptCard.astro";
import ResourceCard from "../components/ResourceCard.astro";
import ScheduleCard from "../components/ScheduleCard.astro";
import {
  byIds,
  createPath,
  formatDate,
  getEventBySlug,
  getModulesByEventId,
  getPrompts,
  getResources,
  getSiteConfig,
} from "../lib/site";

const site = await getSiteConfig();
if (!site) {
  throw new Error("site config is missing");
}

const featuredEvent = await getEventBySlug(site.data.featuredEventSlug);
if (!featuredEvent) {
  throw new Error("featured event is missing");
}

const modules = await getModulesByEventId(featuredEvent.data.id);
const prompts = await getPrompts();
const resources = await getResources();

const featuredPromptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))].slice(0, 2);
const featuredPrompts = byIds(prompts, featuredPromptIds);
const featuredResources = byIds(resources, featuredEvent.data.resourceIds).slice(0, 2);

const prepLink = featuredEvent.data.quickLinks.find((link) => link.label.includes("준비") || link.url.includes("faq"));
const firstModule = modules[0];
---

<BaseLayout
  title="edubeige-lab"
  description="AI 연수를 처음 시작하는 교사도 단계별로 따라올 수 있는 프리미엄 연수 가이드"
  navSection="guide"
  shell="guide"
>
  <section class="landing-hero container">
    <div class="landing-hero__copy">
      <p class="eyebrow">Guide Landing</p>
      <h1>처음 시작하는 선생님도 오늘 연수를 차근차근 따라갈 수 있습니다.</h1>
      <p class="landing-hero__summary">
        edubeige-lab은 AI 연수에서 준비, 실습, 결과 공유까지 순서대로 안내하는 가이드입니다.
        오늘 해야 할 일과 필요한 자료를 한 화면에서 바로 확인할 수 있도록 정리했습니다.
      </p>

      <div class="landing-hero__meta">
        <span class="library-pill">{formatDate(featuredEvent.data.date)}</span>
        <span class="tag">장소: {featuredEvent.data.venue}</span>
        <span class="tag">강사: {featuredEvent.data.speaker}</span>
      </div>

      <div class="button-row">
        <a class="button" href={firstModule ? `${import.meta.env.BASE_URL}modules/${firstModule.data.slug}` : `${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>
          오늘 연수 시작
        </a>
        <a class="button secondary" href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 라이브러리</a>
      </div>
    </div>

    <aside class="landing-hero__panel">
      <p class="landing-hero__panel-eyebrow">오늘 과정 미리보기</p>
      <ul class="landing-hero__steps">
        {modules.map((module, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <strong>{module.data.title}</strong>
              <small>{module.data.startTime} - {module.data.endTime}</small>
            </div>
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="container section">
    <div class="landing-quick-grid">
      <a class="landing-quick-card is-primary" href={prepLink ? createPath(import.meta.env.BASE_URL, prepLink.url) : `${import.meta.env.BASE_URL}faq`}>
        <span>Step 01</span>
        <strong>준비 체크하기</strong>
        <p>로그인, 브라우저, 학교망 문제를 먼저 확인하고 시작하세요.</p>
      </a>

      <a class="landing-quick-card" href={`${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>
        <span>Step 02</span>
        <strong>전체 과정 보기</strong>
        <p>오늘 연수의 전체 흐름과 단계별 이동 경로를 한 번에 확인합니다.</p>
      </a>

      <a class="landing-quick-card" href={`${import.meta.env.BASE_URL}faq`}>
        <span>Step 03</span>
        <strong>문제 해결 바로가기</strong>
        <p>학교망, 복사, 접속 문제를 빠르게 확인할 수 있는 도움말입니다.</p>
      </a>
    </div>
  </section>

  <section class="container section">
    <div class="landing-grid">
      <div class="landing-section-card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Today Schedule</p>
            <h2>오늘 따라갈 단계</h2>
          </div>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>전체 과정 보기</a>
        </div>

        <div class="schedule-list">
          {modules.map((module, index) => (
            <ScheduleCard module={module} index={index} ctaLabel={`${index + 1}교시 열기`} />
          ))}
        </div>
      </div>

      <div class="landing-section-card landing-section-card--compact">
        <div class="section-header">
          <div>
            <p class="eyebrow">Resources</p>
            <h2>오늘 필요한 자료</h2>
          </div>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
        </div>

        <div class="resource-list">
          {featuredResources.map((resource) => <ResourceCard resource={resource} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="landing-library-strip">
      <div class="landing-library-strip__intro">
        <p class="eyebrow">Premium Library</p>
        <h2>실습 중 바로 꺼내 쓰는 프롬프트</h2>
        <p>막히는 순간 바로 복사해서 쓸 수 있도록 핵심 프롬프트만 먼저 보여줍니다.</p>
      </div>

      <div class="prompt-grid prompt-grid--compact">
        {featuredPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
      </div>
    </div>
  </section>
</BaseLayout>
