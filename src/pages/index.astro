---
import BaseLayout from "../components/BaseLayout.astro";
import GalleryCard from "../components/GalleryCard.astro";
import PromptCard from "../components/PromptCard.astro";
import ResourceCard from "../components/ResourceCard.astro";
import ScheduleCard from "../components/ScheduleCard.astro";
import {
  byIds,
  createPath,
  formatDate,
  getEventBySlug,
  getGalleryItems,
  getModulesByEventId,
  getPrompts,
  getResources,
  getSiteConfig,
} from "../lib/site";

const site = await getSiteConfig();
if (!site) {
  throw new Error("site config is missing");
}

const featuredEvent = await getEventBySlug(site.data.featuredEventSlug);
if (!featuredEvent) {
  throw new Error("featured event is missing");
}

const modules = await getModulesByEventId(featuredEvent.data.id);
const prompts = await getPrompts();
const resources = await getResources();
const gallery = await getGalleryItems();

const featuredPromptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))].slice(0, 2);
const featuredPrompts = byIds(prompts, featuredPromptIds);
const featuredResources = byIds(resources, featuredEvent.data.resourceIds);
const featuredGallery = byIds(gallery, featuredEvent.data.galleryIds).slice(0, 3);
---

<BaseLayout title="edubeige-lab" description={site.data.siteSubtitle} navSection="home">
  <section class="hero-section">
    <div class="container">
      <div class="portal-hero">
        <div class="portal-hero__content">
          <span class="pill pill--light">{formatDate(featuredEvent.data.date)}</span>
          <h1>{featuredEvent.data.title}</h1>
          <p class="portal-hero__summary">{featuredEvent.data.heroSummary}</p>
          <p class="portal-hero__meta">장소: {featuredEvent.data.venue} | 강사: {featuredEvent.data.speaker}</p>
          <div class="button-row">
            <a class="button" href={`${import.meta.env.BASE_URL}events/${featuredEvent.data.slug}`}>오늘 연수 보기</a>
            <a class="button secondary" href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 허브</a>
          </div>
        </div>
        <div class="portal-hero__art" aria-hidden="true">
          <div class="hero-orb"></div>
          <div class="hero-signal">
            <span>오늘 운영</span>
            <strong>{modules.length}개 차시</strong>
            <small>준비·실습·공유 흐름을 한 화면에 정리</small>
          </div>
        </div>
      </div>

      <div class="action-grid">
        {featuredEvent.data.quickLinks.slice(0, 3).map((link, index) => (
          <a
            class:list={[
              "action-card",
              index === 0 && "is-primary",
            ]}
            href={createPath(site.data.siteBasePath, link.url)}
            target={link.url.startsWith("http") ? "_blank" : undefined}
            rel="noreferrer"
          >
            <span class="action-card__kicker">{index === 0 ? "Digital Board" : "Quick Access"}</span>
            <strong>{link.label}</strong>
            <small>{index === 0 ? "오늘 연수에서 가장 먼저 열어둘 링크" : "연수 흐름을 끊지 않고 바로 이동"}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="portal-main">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Schedule</p>
            <h2>연수 시간표</h2>
          </div>
          <span class="section-meta">총 {modules.length}차시 운영</span>
        </div>
        <div class="schedule-list">
          {modules.map((module, index) => <ScheduleCard module={module} index={index} />)}
        </div>
      </div>

      <aside class="sidebar-stack">
        <div class="content-panel content-panel--tight">
          <div class="section-header">
            <div>
              <p class="eyebrow">Notice</p>
              <h2>공지 및 준비사항</h2>
            </div>
          </div>
          <div class="notice-stack">
            {featuredEvent.data.notices.map((notice) => (
              <div class="notice-card">
                <strong>운영 안내</strong>
                <p>{notice}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="content-panel content-panel--tight">
          <div class="section-header">
            <div>
              <p class="eyebrow">Tools</p>
              <h2>AI 도구 빠른 접속</h2>
            </div>
          </div>
          <div class="tool-grid">
            {featuredEvent.data.toolLinks.map((tool) => (
              <a class="tool-card" href={tool.url} target="_blank" rel="noreferrer">
                <span class="tool-card__icon">{tool.label.slice(0, 1)}</span>
                <strong>{tool.label}</strong>
                <small>학교망에서 막히면 FAQ의 대체 안내 확인</small>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="container section">
    <div class="split-grid">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Prompt Hub</p>
            <h2>복사하여 바로 쓰는 프롬프트</h2>
          </div>
          <a class="button secondary compact" href={`${import.meta.env.BASE_URL}prompts`}>전체 보기</a>
        </div>
        <div class="prompt-grid prompt-grid--compact">
          {featuredPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
        </div>
      </div>

      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Resources</p>
            <h2>오늘 자료</h2>
          </div>
          <a class="button secondary compact" href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
        </div>
        <div class="resource-list">
          {featuredResources.map((resource) => <ResourceCard resource={resource} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="content-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Gallery</p>
          <h2>실제 적용 사례 미리보기</h2>
        </div>
        <a class="button ghost compact" href={`${import.meta.env.BASE_URL}gallery`}>사례 더 보기</a>
      </div>
      <div class="gallery-grid gallery-grid--triple">
        {featuredGallery.map((item) => <GalleryCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
