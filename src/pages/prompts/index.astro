---
import BaseLayout from "../../components/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import PromptCard from "../../components/PromptCard.astro";
import { getPrompts } from "../../lib/site";

const prompts = await getPrompts();
const tools = [...new Set(prompts.map((prompt) => prompt.data.tool))];
const subjects = [...new Set(prompts.flatMap((prompt) => prompt.data.subjects))];
const purposes = [...new Set(prompts.flatMap((prompt) => prompt.data.purposes))];
const trainingTypes = [...new Set(prompts.flatMap((prompt) => prompt.data.trainingTypes))];
---

<BaseLayout title="프롬프트 허브 | edubeige-lab" navSection="prompts">
  <PageIntro
    eyebrow="Prompt Hub"
    title="프롬프트 허브"
    description="검색과 필터를 중심으로 필요한 수업 프롬프트를 빠르게 찾고, 바로 복사해 실습과 수업에 연결하는 카탈로그형 화면입니다."
    accent="검색 중심 카탈로그"
  />

  <section class="container section">
    <div class="content-panel content-panel--catalog">
      <div class="search-stage">
        <input id="prompt-search" class="search-input" type="search" placeholder="필요한 수업 프롬프트를 검색하세요. 예: 실험 보고서, 토론 활동, 루브릭" />
      </div>

      <div class="filter-stack">
        <div class="filter-cluster">
          <span class="filter-label">AI 도구</span>
          <div class="chip-group" data-filter-group="tool">
            <button class="filter-chip is-active" type="button" data-value="">전체</button>
            {tools.map((tool) => <button class="filter-chip" type="button" data-value={tool}>{tool}</button>)}
          </div>
        </div>

        <div class="filter-cluster">
          <span class="filter-label">교과목</span>
          <div class="chip-group" data-filter-group="subject">
            <button class="filter-chip is-active" type="button" data-value="">전체</button>
            {subjects.map((subject) => <button class="filter-chip" type="button" data-value={subject}>{subject}</button>)}
          </div>
        </div>

        <div class="filter-cluster">
          <span class="filter-label">활용 목적</span>
          <div class="chip-group" data-filter-group="purpose">
            <button class="filter-chip is-active" type="button" data-value="">전체</button>
            {purposes.map((purpose) => <button class="filter-chip" type="button" data-value={purpose}>{purpose}</button>)}
          </div>
        </div>

        <div class="filter-cluster">
          <span class="filter-label">연수 유형</span>
          <div class="chip-group" data-filter-group="training">
            <button class="filter-chip is-active" type="button" data-value="">전체</button>
            {trainingTypes.map((item) => <button class="filter-chip" type="button" data-value={item}>{item}</button>)}
          </div>
        </div>
      </div>

      <div class="prompt-grid" id="prompt-grid">
        {prompts.map((prompt) => <PromptCard prompt={prompt} />)}
      </div>
      <div id="prompt-empty" class="empty-state hidden">조건에 맞는 프롬프트가 없습니다. 다른 교과나 활용 목적을 눌러 보세요.</div>
    </div>
  </section>

  <script>
    import Fuse from "fuse.js";

    const cards = Array.from(document.querySelectorAll("[data-prompt-card]"));
    const searchInput = document.querySelector("#prompt-search");
    const filterGroups = Array.from(document.querySelectorAll("[data-filter-group]"));
    const emptyState = document.querySelector("#prompt-empty");
    const filterState = {
      tool: "",
      subject: "",
      purpose: "",
      training: "",
    };

    if (searchInput instanceof HTMLInputElement) {
      const dataset = cards.map((card) => {
        const payload = JSON.parse(card.getAttribute("data-searchable") ?? "{}");
        return { element: card, ...payload };
      });

      const fuse = new Fuse(dataset, {
        keys: ["title", "summary", "body", "tool", "subjects", "purposes", "trainingTypes"],
        threshold: 0.32,
      });

      const render = () => {
        const query = searchInput.value.trim();
        const searchMatched = query ? new Set(fuse.search(query).map((entry) => entry.item.element)) : null;
        let visibleCount = 0;

        dataset.forEach((item) => {
          const matchesQuery = !searchMatched || searchMatched.has(item.element);
          const matchesTool = !filterState.tool || item.tool === filterState.tool;
          const matchesSubject = !filterState.subject || item.subjects.includes(filterState.subject);
          const matchesPurpose = !filterState.purpose || item.purposes.includes(filterState.purpose);
          const matchesTraining = !filterState.training || item.trainingTypes.includes(filterState.training);
          const visible = matchesQuery && matchesTool && matchesSubject && matchesPurpose && matchesTraining;
          item.element.classList.toggle("hidden", !visible);
          if (visible) visibleCount += 1;
        });

        if (emptyState instanceof HTMLElement) {
          emptyState.classList.toggle("hidden", visibleCount !== 0);
        }
      };

      filterGroups.forEach((group) => {
        group.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof HTMLButtonElement)) return;

          const groupName = group.getAttribute("data-filter-group");
          if (!groupName) return;

          const nextValue = target.dataset.value ?? "";
          if (groupName === "tool") filterState.tool = nextValue;
          if (groupName === "subject") filterState.subject = nextValue;
          if (groupName === "purpose") filterState.purpose = nextValue;
          if (groupName === "training") filterState.training = nextValue;
          Array.from(group.querySelectorAll("button")).forEach((button) => {
            button.classList.toggle("is-active", button === target);
          });
          render();
        });
      });

      searchInput.addEventListener("input", render);
      render();
    }
  </script>
</BaseLayout>
