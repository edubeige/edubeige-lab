---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import {
  byIds,
  createPath,
  formatDate,
  getGalleryItems,
  getModulesByEventId,
  getPrompts,
  getResources,
} from "../../lib/site";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.data.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const modules = await getModulesByEventId(event.data.id);
const prompts = await getPrompts();
const resources = await getResources();
const gallery = await getGalleryItems();

const promptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))];
const relatedPrompts = byIds(prompts, promptIds);
const relatedResources = byIds(resources, event.data.resourceIds);
const relatedGallery = byIds(gallery, event.data.galleryIds);
---

<BaseLayout title={`${event.data.title} | edubeige-lab`} navLabel="Event">
  <PageIntro
    eyebrow="Event Detail"
    title={event.data.title}
    description={event.data.heroSummary}
    accent={formatDate(event.data.date)}
  />

  <section class="container section">
    <div class="two-column">
      <div class="section-shell">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Overview</p>
            <h2>회차 개요</h2>
          </div>
        </div>
        <div class="detail-list">
          <div class="detail-item"><strong>날짜</strong><p>{formatDate(event.data.date)}</p></div>
          <div class="detail-item"><strong>장소</strong><p>{event.data.venue}</p></div>
          <div class="detail-item"><strong>강사</strong><p>{event.data.speaker}</p></div>
        </div>
      </div>
      <div class="section-shell">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Notice</p>
            <h2>공지와 준비사항</h2>
          </div>
        </div>
        <div class="notice-list">
          {event.data.notices.map((notice) => <div class="notice-item">{notice}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-shell">
      <div class="section-copy">
        <div>
          <p class="section-eyebrow">Modules</p>
          <h2>차시 구성</h2>
        </div>
      </div>
      <div class="timeline">
        {modules.map((module) => (
          <a class="timeline-item" href={`${import.meta.env.BASE_URL}modules/${module.data.slug}`}>
            <span class="timeline-time">{module.data.startTime}</span>
            <div>
              <h3>{module.data.title}</h3>
              <p>{module.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="two-column">
      <div class="section-shell">
        <div class="section-head">
          <div class="section-copy">
            <div>
              <p class="section-eyebrow">Resources</p>
              <h2>회차 전용 자료</h2>
            </div>
          </div>
        </div>
        <div class="card-grid">
          {relatedResources.map((resource) => <ResourceCard resource={resource} />)}
        </div>
      </div>
      <div class="section-shell">
        <div class="section-head">
          <div class="section-copy">
            <div>
              <p class="section-eyebrow">Quick Links</p>
              <h2>실습 링크</h2>
            </div>
          </div>
        </div>
        <div class="link-grid">
          {event.data.quickLinks.map((link) => (
            <a class="quick-link" href={createPath(import.meta.env.BASE_URL, link.url)} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              <strong>{link.label}</strong>
              <span class="muted">{link.url}</span>
            </a>
          ))}
          {event.data.toolLinks.map((link) => (
            <a class="tool-link" href={link.url} target="_blank" rel="noreferrer">
              <strong>{link.label}</strong>
              <span class="muted">바로가기</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-shell">
      <div class="section-head">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Prompt Bundle</p>
            <h2>관련 프롬프트</h2>
          </div>
        </div>
      </div>
      <div class="card-grid">
        {relatedPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-shell">
      <div class="section-head">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Gallery</p>
            <h2>결과물 예시</h2>
          </div>
        </div>
      </div>
      <div class="card-grid">
        {relatedGallery.map((item) => <GalleryCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
