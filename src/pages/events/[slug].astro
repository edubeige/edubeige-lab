---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import PromptCard from "../../components/PromptCard.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import ScheduleCard from "../../components/ScheduleCard.astro";
import {
  byIds,
  createPath,
  formatDate,
  getGalleryItems,
  getModulesByEventId,
  getPrompts,
  getResources,
} from "../../lib/site";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.data.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const modules = await getModulesByEventId(event.data.id);
const prompts = await getPrompts();
const resources = await getResources();
const gallery = await getGalleryItems();

const promptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))];
const relatedPrompts = byIds(prompts, promptIds);
const relatedResources = byIds(resources, event.data.resourceIds);
const relatedGallery = byIds(gallery, event.data.galleryIds);
const firstModule = modules[0];
const shareLinks = [...new Map(modules.flatMap((module) => module.data.shareLinks).map((link) => [`${link.label}-${link.url}`, link])).values()];
const preparationItems = [
  ...event.data.notices.slice(0, 2),
  `${event.data.toolLinks.map((tool) => tool.label).join(", ")} 링크를 미리 열어두면 연수 중 덜 막힙니다.`,
].slice(0, 3);
---

<BaseLayout title={`${event.data.title} | edubeige-lab`} navSection="events">
  <section class="hero-section hero-section--compact">
    <div class="container">
      <div class="guide-hero guide-hero--event">
        <div class="guide-hero__main">
          <p class="eyebrow">오늘 연수 전체 안내</p>
          <h1>{event.data.title}</h1>
          <p class="guide-hero__lead">
            이 페이지는 오늘 연수의 전체 흐름을 한 번에 보는 안내서입니다.
            먼저 준비사항을 확인한 뒤, 교시 카드를 위에서 아래 순서대로 열어보세요.
          </p>

          <div class="guide-meta">
            <span class="tag tag--dark">{formatDate(event.data.date)}</span>
            <span class="tag">장소: {event.data.venue}</span>
            <span class="tag">강사: {event.data.speaker}</span>
            <span class="tag">총 {modules.length}개 차시</span>
          </div>

          <div class="button-row">
            <a class="button" href="#event-prepare">준비 체크하러 가기</a>
            {firstModule && <a class="button secondary" href={`${import.meta.env.BASE_URL}modules/${firstModule.data.slug}`}>1교시 시작하기</a>}
          </div>
        </div>

        <aside class="guide-hero__aside">
          <div class="guide-answer">
            <span>먼저 할 일</span>
            <strong>로그인, 브라우저, 학교망 상태를 먼저 확인하세요.</strong>
          </div>
          <div class="guide-answer">
            <span>이 다음에는?</span>
            <strong>교시 카드를 위에서 아래 순서대로 누르면 됩니다.</strong>
          </div>
          <div class="guide-answer">
            <span>필요한 자료는?</span>
            <strong>아래 자료와 프롬프트를 함께 열어두면 진행이 쉬워집니다.</strong>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section id="event-prepare" class="container section">
    <div class="manual-grid">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Step 1</p>
            <h2>연수 전에 준비할 것</h2>
          </div>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}faq`}>문제 해결 보기</a>
        </div>

        <ul class="manual-list">
          {preparationItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="content-panel content-panel--tight">
        <div class="section-header">
          <div>
            <p class="eyebrow">Useful Links</p>
            <h2>필요한 링크 미리 열기</h2>
          </div>
        </div>

        <div class="link-stack">
          {event.data.quickLinks.map((link) => (
            <a class="link-card" href={createPath(import.meta.env.BASE_URL, link.url)} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              <strong>{link.label}</strong>
              <small>연수 전에 한 번 열어두면 진행이 끊기지 않습니다.</small>
            </a>
          ))}

          {event.data.toolLinks.map((link) => (
            <a class="link-card" href={link.url} target="_blank" rel="noreferrer">
              <strong>{link.label} 열기</strong>
              <small>학교망에서 막히면 FAQ의 대체 안내를 확인하세요.</small>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="content-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Step 2</p>
          <h2>오늘 차시 순서</h2>
          <p class="section-summary">아래 교시 카드를 위에서 아래 순서대로 누르면, 각 차시의 실습 안내 페이지로 바로 이동합니다.</p>
        </div>
      </div>

      <div class="schedule-list">
        {modules.map((module, index) => (
          <ScheduleCard module={module} index={index} ctaLabel={`${index + 1}교시 안내 보기`} />
        ))}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="split-grid">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Step 3</p>
            <h2>필요한 자료와 링크</h2>
          </div>
          <a class="button secondary compact" href={`${import.meta.env.BASE_URL}resources`}>자료 더 보기</a>
        </div>
        <div class="resource-list">
          {relatedResources.map((resource) => <ResourceCard resource={resource} />)}
        </div>
      </div>

      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Prompt Support</p>
            <h2>실습 중 바로 쓰는 프롬프트</h2>
          </div>
          <a class="button secondary compact" href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 더 보기</a>
        </div>
        <div class="prompt-grid prompt-grid--compact">
          {relatedPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="cta-banner cta-banner--guide">
      <div>
        <span class="eyebrow">Step 4</span>
        <h2>마지막에는 결과를 공유하세요</h2>
        <p>오늘 만든 결과물을 공유 링크에 올리면 서로의 사례를 참고하고 이후 연수 자료로도 다시 활용할 수 있습니다.</p>
      </div>
      <div class="button-row">
        {shareLinks.map((link) => (
          <a class="button" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
        ))}
      </div>
    </div>
  </section>

  {relatedGallery.length > 0 && (
    <section class="container section">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Examples</p>
            <h2>참고 사례</h2>
          </div>
          <a class="button ghost compact" href={`${import.meta.env.BASE_URL}gallery`}>사례 더 보기</a>
        </div>

        <div class="gallery-grid gallery-grid--double">
          {relatedGallery.map((item) => <GalleryCard item={item} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
