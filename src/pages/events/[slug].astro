---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import WorkspaceSidebar from "../../components/WorkspaceSidebar.astro";
import {
  byIds,
  createPath,
  formatDate,
  getModulesByEventId,
  getPrompts,
  getResources,
} from "../../lib/site";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.data.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const modules = await getModulesByEventId(event.data.id);
const prompts = await getPrompts();
const resources = await getResources();

const promptIds = [...new Set(modules.flatMap((module) => module.data.promptIds))].slice(0, 2);
const relatedPrompts = byIds(prompts, promptIds);
const relatedResources = byIds(resources, event.data.resourceIds);
const firstModule = modules[0];
const preparationItems = [
  ...event.data.notices,
  `${event.data.toolLinks.map((tool) => tool.label).join(", ")} 링크를 미리 열어두면 진행이 훨씬 수월합니다.`,
];
---

<BaseLayout title={`${event.data.title} | edubeige-lab`} navSection="events" shell="workspace">
  <section class="container section">
    <div class="workspace-layout">
      <WorkspaceSidebar
        modules={modules}
        title="과정 시작 전"
        summary="왼쪽 단계 목록에서 차시를 확인하고, 오른쪽 안내를 읽은 뒤 첫 번째 단계부터 시작하세요."
      />

      <div class="workspace-main">
        <nav class="workspace-breadcrumb" aria-label="경로">
          <a href={`${import.meta.env.BASE_URL}`}>가이드 홈</a>
          <span>›</span>
          <span>{event.data.title}</span>
        </nav>

        <header class="workspace-lead">
          <p class="workspace-lead__eyebrow">Course Overview</p>
          <h1>{event.data.title}</h1>
          <p>{event.data.heroSummary}</p>
        </header>

        <section class="workspace-stage">
          <div class="workspace-stage__top">
            <div>
              <p class="eyebrow">오늘 과정 안내</p>
              <h2>먼저 전체 흐름을 확인하세요</h2>
            </div>
            <span class="workspace-state-chip">{formatDate(event.data.date)}</span>
          </div>

          <div class="workspace-stage__surface">
            <div class="workspace-stage__copy">
              <p>
                이 페이지는 오늘 연수의 전체 흐름을 먼저 이해하는 과정 개요 화면입니다.
                준비 사항을 확인한 뒤, 아래 버튼으로 첫 번째 차시를 시작하거나 왼쪽 단계 목록에서 원하는 차시로 이동하세요.
              </p>

              <div class="workspace-stage__meta">
                <span class="tag">장소: {event.data.venue}</span>
                <span class="tag">강사: {event.data.speaker}</span>
                <span class="tag">총 {modules.length}단계</span>
              </div>
            </div>

            <div class="button-row">
              {firstModule && <a class="button" href={`${import.meta.env.BASE_URL}modules/${firstModule.data.slug}`}>첫 단계 시작하기</a>}
              <a class="button secondary" href={`${import.meta.env.BASE_URL}faq`}>막히면 도움말 보기</a>
            </div>
          </div>
        </section>

        <div class="workspace-subgrid">
          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">준비 사항</p>
                <h2>시작 전에 체크할 것</h2>
              </div>
            </div>
            <ul class="manual-list">
              {preparationItems.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">빠른 링크</p>
                <h2>미리 열어두면 좋은 링크</h2>
              </div>
            </div>

            <div class="link-stack">
              {event.data.quickLinks.map((link) => (
                <a class="link-card" href={createPath(import.meta.env.BASE_URL, link.url)} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
                  <strong>{link.label}</strong>
                  <small>연수 전 한 번 열어두면 진행이 끊기지 않습니다.</small>
                </a>
              ))}
              {event.data.toolLinks.map((tool) => (
                <a class="link-card" href={tool.url} target="_blank" rel="noreferrer">
                  <strong>{tool.label} 열기</strong>
                  <small>학교망에서 막히면 문제 해결 페이지를 먼저 확인하세요.</small>
                </a>
              ))}
            </div>
          </section>
        </div>

        <section class="workspace-card">
          <div class="section-header">
            <div>
              <p class="eyebrow">필요한 자료</p>
              <h2>오늘 바로 여는 자료</h2>
            </div>
            <a class="button ghost compact" href={`${import.meta.env.BASE_URL}resources`}>자료실 보기</a>
          </div>
          <div class="resource-list">
            {relatedResources.map((resource) => <ResourceCard resource={resource} />)}
          </div>
        </section>

        <section class="workspace-card">
          <div class="section-header">
            <div>
              <p class="eyebrow">관련 프롬프트</p>
              <h2>실습 전에 미리 보고 들어가기</h2>
            </div>
            <a class="button ghost compact" href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 더 보기</a>
          </div>
          <div class="library-prompt-grid library-prompt-grid--compact">
            {relatedPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
