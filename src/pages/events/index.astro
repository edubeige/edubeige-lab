---
import BaseLayout from "../../components/BaseLayout.astro";
import EventCard from "../../components/EventCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import { getEvents } from "../../lib/site";

const events = await getEvents();
const featured = events.at(-1);
const archive = events.slice(0, -1).reverse();
---

<BaseLayout title="연수 일정 | edubeige-lab" navLabel="Events">
  <PageIntro
    eyebrow="Events"
    title="연수 일정과 아카이브"
    description="현재 운영 중인 연수와 이전 회차를 함께 관리하는 목록입니다."
    accent="복제 가능한 회차 중심 운영"
  />

  {featured && (
    <section class="container section">
      <div class="section-shell">
        <div class="section-copy">
          <div>
            <p class="section-eyebrow">Current</p>
            <h2>최근 회차</h2>
          </div>
        </div>
        <div class="card-grid">
          <EventCard event={featured} />
        </div>
      </div>
    </section>
  )}

  <section class="container section">
    <div class="section-shell">
      <div class="section-copy">
        <div>
          <p class="section-eyebrow">Archive</p>
          <h2>이전 회차</h2>
          <p>회차를 복제해 새 연수를 만들 수 있도록 제목, 일정, 자료, 모듈 구조를 유지합니다.</p>
        </div>
      </div>
      <div class="card-grid">
        {archive.map((event) => <EventCard event={event} />)}
      </div>
    </div>
  </section>
</BaseLayout>
