---
import BaseLayout from "../../components/BaseLayout.astro";
import EventCard from "../../components/EventCard.astro";
import { getEvents } from "../../lib/site";

const events = await getEvents();
const featured = events.at(-1);
const archive = events.slice(0, -1).reverse();
---

<BaseLayout title="연수 과정 | edubeige-lab" navSection="events" shell="workspace">
  <section class="library-hero library-hero--compact container">
    <div class="library-hero__copy">
      <p class="eyebrow">Course Archive</p>
      <h1>연수 과정과 회차 아카이브</h1>
      <p class="library-hero__summary">
        현재 운영 중인 과정과 이전 연수 회차를 한눈에 정리했습니다.
        필요할 때 전체 흐름을 복기하거나 다음 연수 설계의 참고 자료로 활용할 수 있습니다.
      </p>
    </div>
  </section>

  {featured && (
    <section class="container section">
      <div class="library-feed library-feed--single">
        <div class="library-feed__header">
          <div>
            <p class="eyebrow">Current Course</p>
            <h2>현재 운영 중인 과정</h2>
          </div>
        </div>
        <EventCard event={featured} />
      </div>
    </section>
  )}

  <section class="container section">
    <div class="library-feed library-feed--single">
      <div class="library-feed__header">
        <div>
          <p class="eyebrow">Archive</p>
          <h2>이전 과정</h2>
        </div>
        <span class="section-meta">{archive.length}개 과정</span>
      </div>

      <div class="event-grid">
        {archive.map((event) => <EventCard event={event} />)}
      </div>
    </div>
  </section>
</BaseLayout>
