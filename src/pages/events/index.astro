---
import BaseLayout from "../../components/BaseLayout.astro";
import EventCard from "../../components/EventCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import { getEvents } from "../../lib/site";

const events = await getEvents();
const featured = events.at(-1);
const archive = events.slice(0, -1).reverse();
---

<BaseLayout title="연수 일정 | edubeige-lab" navSection="events">
  <PageIntro
    eyebrow="Events"
    title="연수 일정과 회차 아카이브"
    description="이전 회차를 복제해 새 연수를 빠르게 운영할 수 있도록, 일정과 구조를 회차 중심으로 정리했습니다."
    accent="복제 가능한 연수 포털 구조"
  />

  {featured && (
    <section class="container section">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Current Event</p>
            <h2>최근 운영 회차</h2>
          </div>
        </div>
        <EventCard event={featured} />
      </div>
    </section>
  )}

  <section class="container section">
    <div class="content-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Archive</p>
          <h2>이전 회차</h2>
        </div>
        <span class="section-meta">{archive.length}개 회차</span>
      </div>
      <div class="event-grid">
        {archive.map((event) => <EventCard event={event} />)}
      </div>
    </div>
  </section>
</BaseLayout>
