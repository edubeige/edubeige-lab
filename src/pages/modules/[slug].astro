---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import { byIds, getEvents, getPrompts, getResources } from "../../lib/site";

export async function getStaticPaths() {
  const modules = await getCollection("modules");
  return modules.map((module) => ({
    params: { slug: module.data.slug },
    props: { module },
  }));
}

const { module } = Astro.props;
const events = await getEvents();
const prompts = await getPrompts();
const resources = await getResources();
const event = events.find((item) => item.data.id === module.data.eventId);
const relatedPrompts = byIds(prompts, module.data.promptIds);
const relatedResources = byIds(resources, module.data.resourceIds);
const moduleLabel = `MODULE ${String(module.data.order).padStart(2, "0")}`;
---

<BaseLayout title={`${module.data.title} | edubeige-lab`} navSection="events">
  <section class="hero-section hero-section--compact">
    <div class="container">
      <div class="module-hero">
        <div class="module-hero__content">
          <span class="pill pill--soft">{moduleLabel}</span>
          <h1>{module.data.order}교시: {module.data.title}</h1>
          <p class="module-hero__summary">{module.data.summary}</p>
          <div class="tag-row">
            <span class="tag tag--dark">{module.data.startTime} - {module.data.endTime}</span>
            {module.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <div class="button-row">
            {event && <a class="button secondary" href={`${import.meta.env.BASE_URL}events/${event.data.slug}`}>회차로 돌아가기</a>}
            <a class="button ghost" href={`${import.meta.env.BASE_URL}faq`}>문제 해결 보기</a>
          </div>
        </div>

        <aside class="module-hero__aside">
          <span class="module-hero__eyebrow">이 모듈에서 얻는 것</span>
          <div class="goal-list">
            {module.data.learningGoals.map((goal) => (
              <div class="goal-item">
                <strong>목표</strong>
                <p>{goal}</p>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="module-board">
      <div class="content-panel content-panel--tight">
        <div class="section-header">
          <div>
            <p class="eyebrow">Checklist</p>
            <h2>실습 준비하기</h2>
          </div>
        </div>
        <div class="checklist-stack">
          {module.data.checklist.map((item) => (
            <label class="checklist-item">
              <input type="checkbox" />
              <span>{item}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Guide</p>
            <h2>단계별 실습 가이드</h2>
          </div>
        </div>
        <div class="guide-flow">
          {module.data.steps.map((step, index) => (
            <div class="guide-step">
              <div class="guide-step__marker">{index + 1}</div>
              <div class="guide-step__card">
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="split-grid">
      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Prompt Cards</p>
            <h2>복사하여 바로 쓰는 프롬프트 카드</h2>
          </div>
        </div>
        <div class="prompt-grid prompt-grid--compact">
          {relatedPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
        </div>
      </div>

      <div class="content-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">Resources</p>
            <h2>함께 보는 자료</h2>
          </div>
        </div>
        <div class="resource-list">
          {relatedResources.map((resource) => <ResourceCard resource={resource} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="cta-banner">
      <div>
        <span class="eyebrow">Share</span>
        <h2>오늘의 결과물을 공유해 보세요</h2>
        <p>모둠 결과를 공유하고, 이후 갤러리 사례로 다시 재활용할 수 있도록 흐름을 열어둡니다.</p>
      </div>
      <div class="button-row">
        {module.data.shareLinks.map((link) => (
          <a class="button" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
