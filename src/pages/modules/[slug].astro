---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import WorkspaceSidebar from "../../components/WorkspaceSidebar.astro";
import { getAdjacentModules, getPromptCuration } from "../../lib/presentation";
import {
  byIds,
  getEvents,
  getModulesByEventId,
  getPrompts,
  getResources,
} from "../../lib/site";

export async function getStaticPaths() {
  const modules = await getCollection("modules");
  return modules.map((module) => ({
    params: { slug: module.data.slug },
    props: { module },
  }));
}

const { module } = Astro.props;
const events = await getEvents();
const event = events.find((item) => item.data.id === module.data.eventId);
const eventModules = await getModulesByEventId(module.data.eventId);
const prompts = await getPrompts();
const resources = await getResources();

const relatedPrompts = byIds(prompts, module.data.promptIds);
const relatedResources = byIds(resources, module.data.resourceIds);
const heroPrompt = relatedPrompts[0];
const heroPromptMeta = heroPrompt ? getPromptCuration(heroPrompt.data.id) : undefined;
const adjacent = getAdjacentModules(eventModules, module.data.slug);
---

<BaseLayout title={`${module.data.title} | edubeige-lab`} navSection="events" shell="workspace">
  <section class="container section">
    <div class="workspace-layout">
      <WorkspaceSidebar
        modules={eventModules}
        currentSlug={module.data.slug}
        title="현재 진행률"
        summary={module.data.learningGoals[0] ?? module.data.summary}
      />

      <div class="workspace-main">
        <nav class="workspace-breadcrumb" aria-label="경로">
          {event && <a href={`${import.meta.env.BASE_URL}events/${event.data.slug}`}>{event.data.title}</a>}
          <span>›</span>
          <span>{module.data.order}단계</span>
        </nav>

        <header class="workspace-lead">
          <p class="workspace-lead__eyebrow">Step {String(module.data.order).padStart(2, "0")}</p>
          <h1>{module.data.title}</h1>
          <p>{module.data.summary}</p>
        </header>

        {heroPrompt && (
          <section class="workspace-stage">
            <div class="workspace-stage__top">
              <div>
                <p class="eyebrow">프롬프트 샌드박스</p>
                <h2>{heroPrompt.data.title}</h2>
              </div>
              <div class="workspace-stage__badges">
                <span class="workspace-state-chip">{heroPromptMeta?.category ?? "핵심 프롬프트"}</span>
                {heroPromptMeta?.rating && <span class="workspace-rating-chip">★ {heroPromptMeta.rating}</span>}
              </div>
            </div>

            <div class="workspace-stage__surface">
              <div class="workspace-sandbox">
                <p>{heroPrompt.data.template}</p>
              </div>

              <div class="workspace-stage__actions">
                <button class="button" type="button" data-copy={heroPrompt.data.template}>프롬프트 복사하기</button>
              </div>
            </div>
          </section>
        )}

        <div class="workspace-subgrid">
          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">실습 준비</p>
                <h2>체크하고 시작하기</h2>
              </div>
            </div>
            <div class="checklist-stack">
              {module.data.checklist.map((item) => (
                <label class="checklist-item">
                  <input type="checkbox" />
                  <span>{item}</span>
                </label>
              ))}
            </div>
          </section>

          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">실습 순서</p>
                <h2>이 순서대로 따라오기</h2>
              </div>
            </div>
            <div class="guide-flow">
              {module.data.steps.map((step, index) => (
                <div class="guide-step">
                  <div class="guide-step__marker">{index + 1}</div>
                  <div class="guide-step__card">
                    <h3>{step.title}</h3>
                    <p>{step.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </div>

        {relatedPrompts.length > 0 && (
          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">관련 라이브러리</p>
                <h2>함께 쓰면 좋은 프롬프트</h2>
              </div>
            </div>
            <div class="library-prompt-grid library-prompt-grid--compact">
              {relatedPrompts.map((prompt) => <PromptCard prompt={prompt} />)}
            </div>
          </section>
        )}

        {relatedResources.length > 0 && (
          <section class="workspace-card">
            <div class="section-header">
              <div>
                <p class="eyebrow">관련 자료</p>
                <h2>실습에 필요한 파일</h2>
              </div>
            </div>
            <div class="resource-list">
              {relatedResources.map((resource) => <ResourceCard resource={resource} />)}
            </div>
          </section>
        )}

        <div class="workspace-nav-actions">
          {adjacent.previous ? (
            <a class="button secondary" href={`${import.meta.env.BASE_URL}modules/${adjacent.previous.data.slug}`}>
              이전 단계로
            </a>
          ) : (
            <span></span>
          )}

          {adjacent.next ? (
            <a class="button" href={`${import.meta.env.BASE_URL}modules/${adjacent.next.data.slug}`}>
              다음 단계로
            </a>
          ) : (
            <a class="button" href={event ? `${import.meta.env.BASE_URL}events/${event.data.slug}` : `${import.meta.env.BASE_URL}`}>
              과정 개요로 돌아가기
            </a>
          )}
        </div>

        <section class="workspace-share-banner">
          <div>
            <p class="eyebrow">결과 공유</p>
            <h2>마지막에는 결과를 공유하세요</h2>
            <p>실습 결과를 공유하고, 다른 선생님들의 결과물도 함께 참고하면서 아이디어를 확장해보세요.</p>
          </div>
          <div class="button-row">
            {module.data.shareLinks.map((link) => (
              <a class="button secondary compact" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
