---
import type { GalleryEntry } from "../lib/site";
import { toUiToken } from "../lib/site";

interface Props {
  item: GalleryEntry;
}

const { item } = Astro.props;
---

<article
  class="library-gallery-card"
  data-gallery-card
  data-tool={toUiToken(item.data.tool)}
  data-searchable={JSON.stringify(item.data)}
>
  <div class="library-gallery-card__media">
    <img src={item.data.thumbnail} alt={item.data.title} loading="lazy" />
    <div class="library-gallery-card__overlay">
      <span class="library-pill">{item.data.tool}</span>
    </div>
  </div>

  <div class="library-gallery-card__body">
    <h3>{item.data.title}</h3>
    <p>{item.data.summary}</p>
    <div class="tag-row tag-row--compact">
      {item.data.purposes.map((purpose) => <span class="tag">{purpose}</span>)}
    </div>
    <small>{item.data.detail}</small>
  </div>
</article>
