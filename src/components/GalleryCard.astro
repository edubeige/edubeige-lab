---
import type { GalleryEntry } from "../lib/site";

interface Props {
  item: GalleryEntry;
}

const { item } = Astro.props;
---

<article class="card gallery-card" data-gallery-card data-searchable={JSON.stringify(item.data)}>
  <img src={item.data.thumbnail} alt="" loading="lazy" />
  <div class="gallery-body">
    <div class="card-topline">
      <span>{item.data.tool}</span>
      <span>{item.data.subjects.join(", ")}</span>
    </div>
    <h3>{item.data.title}</h3>
    <p>{item.data.summary}</p>
    <small>{item.data.detail}</small>
  </div>
</article>
