---
import "../styles/global.css";
import { getSiteConfig } from "../lib/site";

type ShellKind = "guide" | "library" | "workspace";

interface Props {
  title: string;
  description?: string;
  navSection?: string;
  shell?: ShellKind;
  searchAction?: string;
  searchPlaceholder?: string;
}

const {
  title,
  description = "교원을 위한 AI 연수 안내서와 프리미엄 실습 라이브러리",
  navSection = "guide",
  shell = "guide",
  searchAction,
  searchPlaceholder = "자료를 검색해보세요...",
} = Astro.props;

const site = await getSiteConfig();
const featuredEventHref = site
  ? `${import.meta.env.BASE_URL}events/${site.data.featuredEventSlug}`
  : `${import.meta.env.BASE_URL}events`;

const shellNav = {
  guide: [
    { id: "guide", href: `${import.meta.env.BASE_URL}`, label: "가이드 홈" },
    { id: "events", href: featuredEventHref, label: "오늘 연수" },
    { id: "faq", href: `${import.meta.env.BASE_URL}faq`, label: "문제 해결" },
  ],
  library: [
    { id: "prompts", href: `${import.meta.env.BASE_URL}prompts`, label: "프롬프트" },
    { id: "resources", href: `${import.meta.env.BASE_URL}resources`, label: "자료실" },
    { id: "gallery", href: `${import.meta.env.BASE_URL}gallery`, label: "사례" },
  ],
  workspace: [
    { id: "events", href: featuredEventHref, label: "과정 홈" },
    { id: "prompts", href: `${import.meta.env.BASE_URL}prompts`, label: "프롬프트 라이브러리" },
    { id: "resources", href: `${import.meta.env.BASE_URL}resources`, label: "자료실" },
  ],
} satisfies Record<ShellKind, { id: string; href: string; label: string }[]>;

const shellCopy = {
  guide: {
    title: "edubeige-lab",
    subtitle: "처음 시작하는 교사를 위한 AI 연수 가이드",
    action: { href: featuredEventHref, label: "오늘 연수 시작" },
  },
  library: {
    title: "edubeige-lab",
    subtitle: "교사를 위한 프리미엄 실습 라이브러리",
    action: { href: `${import.meta.env.BASE_URL}faq`, label: "문제 해결" },
  },
  workspace: {
    title: "edubeige-lab",
    subtitle: "단계별 실습을 따라가는 코스 워크스페이스",
    action: { href: `${import.meta.env.BASE_URL}gallery`, label: "사례 보기" },
  },
} satisfies Record<ShellKind, { title: string; subtitle: string; action: { href: string; label: string } }>;

const config = shellCopy[shell];
const navItems = shellNav[shell];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class:list={["theme-shell", `theme-shell--${shell}`]}>
    <div class:list={["app-shell", `app-shell--${shell}`]}>
      <header class:list={["site-header", `site-header--${shell}`]}>
        <div class="container site-header__inner">
          <a class="brand" href={`${import.meta.env.BASE_URL}`}>
            <span class="brand-mark" aria-hidden="true">EB</span>
            <span class="brand-copy">
              <strong>{config.title}</strong>
              <small>{config.subtitle}</small>
            </span>
          </a>

          <nav class="site-nav" aria-label="주요 메뉴">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "site-nav__link",
                  navSection === item.id && "is-active",
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>

          {shell === "library" && searchAction ? (
            <form class="site-header__search" action={searchAction} method="get">
              <label class="visually-hidden" for="header-search">검색</label>
              <input id="header-search" name="q" type="search" placeholder={searchPlaceholder} />
            </form>
          ) : null}

          <div class="site-header__actions">
            <a class="button secondary compact" href={config.action.href}>{config.action.label}</a>
          </div>
        </div>
      </header>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__brand">
            <strong>edubeige-lab</strong>
            <p>교사를 위한 AI 연수 안내서와 실습 라이브러리</p>
          </div>

          <div class="site-footer__links">
            <a href={`${import.meta.env.BASE_URL}prompts`}>프롬프트</a>
            <a href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
            <a href={`${import.meta.env.BASE_URL}gallery`}>사례</a>
            <a href={`${import.meta.env.BASE_URL}faq`}>문제 해결</a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      document.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const button = target.closest("[data-copy]");
        if (!(button instanceof HTMLButtonElement)) return;

        const text = button.dataset.copy ?? "";
        if (!text) return;

        const originalLabel = button.textContent ?? "복사";

        try {
          await navigator.clipboard.writeText(text);
          button.textContent = "복사 완료";
        } catch {
          window.prompt("복사해서 사용하세요.", text);
          button.textContent = "복사 안내";
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1800);
      });
    </script>
  </body>
</html>
