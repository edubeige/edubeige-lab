---
import "../styles/global.css";
import { getSiteConfig } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  navSection?: string;
}

const {
  title,
  description = "AI 연수를 처음 시작하는 선생님을 위한 단계형 연수 안내서",
  navSection = "guide",
} = Astro.props;

const site = await getSiteConfig();
const todayHref = site
  ? `${import.meta.env.BASE_URL}events/${site.data.featuredEventSlug}`
  : `${import.meta.env.BASE_URL}events`;

const navItems = [
  { id: "guide", href: `${import.meta.env.BASE_URL}#start-here`, label: "시작하기" },
  { id: "events", href: todayHref, label: "오늘 연수" },
  { id: "faq", href: `${import.meta.env.BASE_URL}faq`, label: "문제 해결" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="brand" href={`${import.meta.env.BASE_URL}`}>
            <span class="brand-mark" aria-hidden="true">EB</span>
            <span class="brand-copy">
              <strong>edubeige-lab</strong>
              <small>초보 선생님도 바로 따라가는 AI 연수 안내서</small>
            </span>
          </a>

          <nav class="site-nav" aria-label="주요 메뉴">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "site-nav__link",
                  navSection === item.id && "is-active",
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__brand">
            <strong>edubeige-lab</strong>
            <p>오늘 연수에서 준비, 실습, 공유까지 순서대로 따라가는 교원 연수 안내서</p>
          </div>

          <div class="site-footer__links">
            <a href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 허브</a>
            <a href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
            <a href={`${import.meta.env.BASE_URL}gallery`}>사례 갤러리</a>
            <a href={`${import.meta.env.BASE_URL}faq`}>문제 해결</a>
            <a href={`${import.meta.env.BASE_URL}admin`}>운영자</a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      document.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const button = target.closest("[data-copy]");
        if (!(button instanceof HTMLButtonElement)) return;

        const text = button.dataset.copy ?? "";
        if (!text) return;

        const originalLabel = button.textContent ?? "복사";

        try {
          await navigator.clipboard.writeText(text);
          button.textContent = "복사 완료";
        } catch {
          window.prompt("복사해서 사용하세요.", text);
          button.textContent = "복사 안내";
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1800);
      });
    </script>
  </body>
</html>
