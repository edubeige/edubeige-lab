---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  navSection?: string;
}

const {
  title,
  description = "교원 연수 운영을 위한 실습형 콘텐츠 허브",
  navSection = "home",
} = Astro.props;

const navItems = [
  { id: "home", href: "", label: "홈" },
  { id: "events", href: "events", label: "연수 일정" },
  { id: "prompts", href: "prompts", label: "프롬프트 허브" },
  { id: "resources", href: "resources", label: "자료실" },
  { id: "gallery", href: "gallery", label: "사례 갤러리" },
  { id: "faq", href: "faq", label: "FAQ" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="brand" href={`${import.meta.env.BASE_URL}`}>
            <span class="brand-mark" aria-hidden="true">EB</span>
            <span class="brand-copy">
              <strong>edubeige-lab</strong>
              <small>교원 연수 운영 허브</small>
            </span>
          </a>
          <nav class="site-nav" aria-label="주요 메뉴">
            {navItems.map((item) => (
              <a
                href={`${import.meta.env.BASE_URL}${item.href}`}
                class:list={[
                  "site-nav__link",
                  navSection === item.id && "is-active",
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>
          <div class="site-header__actions">
            <span class="site-header__badge">GitHub Pages</span>
            <a class="button secondary compact" href={`${import.meta.env.BASE_URL}admin`}>/admin</a>
          </div>
        </div>
      </header>
      <main class="page-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__brand">
            <strong>edubeige-lab</strong>
            <p>학교 현장에서 바로 쓰는 연수 운영 포털과 콘텐츠 허브</p>
          </div>
          <div class="site-footer__links">
            <a href={`${import.meta.env.BASE_URL}events`}>연수 일정</a>
            <a href={`${import.meta.env.BASE_URL}prompts`}>프롬프트 허브</a>
            <a href={`${import.meta.env.BASE_URL}resources`}>자료실</a>
            <a href={`${import.meta.env.BASE_URL}faq`}>문제 해결</a>
          </div>
        </div>
      </footer>
    </div>
    <script>
      document.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const button = target.closest("[data-copy]");
        if (!(button instanceof HTMLButtonElement)) return;

        const text = button.dataset.copy ?? "";
        if (!text) return;

        const originalLabel = button.textContent ?? "복사";

        try {
          await navigator.clipboard.writeText(text);
          button.textContent = "복사 완료";
        } catch {
          window.prompt("복사해서 사용하세요", text);
          button.textContent = "복사 안내";
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1800);
      });
    </script>
  </body>
</html>
