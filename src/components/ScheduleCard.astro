---
import type { ModuleEntry } from "../lib/site";

interface Props {
  module: ModuleEntry;
  index: number;
  ctaLabel?: string;
}

const {
  module,
  index,
  ctaLabel = `${index + 1}교시 시작하기`,
} = Astro.props;
---

<a class="schedule-card" href={`${import.meta.env.BASE_URL}modules/${module.data.slug}`}>
  <div class="schedule-card__slot">
    <span class="schedule-card__period">{index + 1}교시</span>
    <strong>{module.data.startTime} - {module.data.endTime}</strong>
  </div>

  <div class="schedule-card__body">
    <h3>{module.data.title}</h3>
    <p>{module.data.summary}</p>

    <div class="schedule-card__footer">
      <div class="tag-row tag-row--compact">
        {module.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <span class="schedule-card__cta">{ctaLabel}</span>
    </div>
  </div>
</a>
