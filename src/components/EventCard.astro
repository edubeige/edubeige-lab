---
import type { EventEntry } from "../lib/site";
import { formatDate } from "../lib/site";

interface Props {
  event: EventEntry;
}

const { event } = Astro.props;
---

<article class="event-summary-card">
  <div class="event-summary-card__meta">
    <span class="library-pill">{formatDate(event.data.date)}</span>
    <span>{event.data.speaker}</span>
  </div>

  <h3>{event.data.title}</h3>
  <p>{event.data.heroSummary}</p>

  <div class="event-summary-card__footer">
    <span>{event.data.venue}</span>
    <a class="button secondary compact" href={`${import.meta.env.BASE_URL}events/${event.data.slug}`}>과정 보기</a>
  </div>
</article>
