---
import type { EventEntry } from "../lib/site";
import { formatDate } from "../lib/site";

interface Props {
  event: EventEntry;
}

const { event } = Astro.props;
---

<article class="card event-card">
  <div class="card-topline">
    <span>{formatDate(event.data.date)}</span>
    <span>{event.data.venue}</span>
  </div>
  <h3>{event.data.title}</h3>
  <p>{event.data.heroSummary}</p>
  <div class="card-meta">
    <span>{event.data.speaker}</span>
    <a href={`${import.meta.env.BASE_URL}events/${event.data.slug}`}>상세 보기</a>
  </div>
</article>
