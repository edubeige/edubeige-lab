---
import type { PromptEntry } from "../lib/site";
import { toUiToken } from "../lib/site";

interface Props {
  prompt: PromptEntry;
}

const { prompt } = Astro.props;
const bodyText = prompt.body.trim();
const tags = [...prompt.data.subjects, ...prompt.data.purposes, ...prompt.data.trainingTypes];
---

<article
  class="prompt-card"
  data-prompt-card
  data-tool={toUiToken(prompt.data.tool)}
  data-searchable={JSON.stringify({
    title: prompt.data.title,
    summary: prompt.data.summary,
    tool: prompt.data.tool,
    subjects: prompt.data.subjects,
    purposes: prompt.data.purposes,
    trainingTypes: prompt.data.trainingTypes,
    difficulty: prompt.data.difficulty,
    body: bodyText,
  })}
>
  <div class="prompt-card__top">
    <div class="prompt-card__badges">
      <span class="badge badge--tool">{prompt.data.tool}</span>
      <span class="badge badge--neutral">{prompt.data.difficulty}</span>
    </div>
    <span class="prompt-card__copy-hint">복사하여 바로 사용</span>
  </div>
  <h3>{prompt.data.title}</h3>
  <p class="prompt-card__summary">{prompt.data.summary}</p>
  <div class="tag-row tag-row--compact">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="prompt-card__preview">
    <strong>템플릿 미리보기</strong>
    <p>{prompt.data.template}</p>
  </div>
  <div class="prompt-card__footer">
    <span>{prompt.data.notes}</span>
    <button class="button" type="button" data-copy={prompt.data.template}>프롬프트 복사</button>
  </div>
</article>
