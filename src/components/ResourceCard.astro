---
import type { ResourceEntry } from "../lib/site";
import { toUiToken } from "../lib/site";

interface Props {
  resource: ResourceEntry;
}

const { resource } = Astro.props;
const typeToken = toUiToken(resource.data.type);
const typeLabel = resource.data.type.toUpperCase();
const scopeLabel = resource.data.scope === "event" ? "오늘 연수 자료" : "공통 자료";
---

<article
  class="library-resource-card"
  data-resource-card
  data-type={typeToken}
  data-scope={resource.data.scope}
  data-searchable={JSON.stringify(resource.data)}
>
  <div class="library-resource-card__icon" data-type={typeToken}>{typeLabel}</div>

  <div class="library-resource-card__body">
    <div class="library-resource-card__meta">
      <span class="library-pill">{scopeLabel}</span>
      <span class="library-resource-card__type">{typeLabel}</span>
    </div>
    <h3>{resource.data.title}</h3>
    <p>{resource.data.description}</p>
  </div>

  <div class="library-resource-card__actions">
    <small>{resource.data.scope === "event" ? "연수 중 바로 여는 자료" : "반복 참고용 자료"}</small>
    <a class="button secondary compact" href={resource.data.url} target="_blank" rel="noreferrer">{resource.data.downloadLabel}</a>
  </div>
</article>
